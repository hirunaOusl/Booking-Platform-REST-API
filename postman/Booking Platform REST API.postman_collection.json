    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData;",
                  "const contentType = pm.response.headers.get('Content-Type') || '';",
                  "if (contentType.includes('application/json')) {",
                  "    jsonData = pm.response.json();",
                  "}",
                  "",
                  "pm.test('Register returns a success status', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Register response is JSON when a body is returned', function () {",
                  "    if (pm.response.text()) {",
                  "        pm.expect(contentType).to.include('application/json');",
                  "    } else {",
                  "        pm.expect(pm.response.text()).to.eql('');",
                  "    }",
                  "});",
                  "",
                  "if (jsonData) {",
                  "    pm.test('Register response includes a success indicator or created user data', function () {",
                  "        const hasSignal = !!(",
                  "            jsonData.id ||",
                  "            jsonData.user ||",
                  "            jsonData.email ||",
                  "            jsonData.message ||",
                  "            jsonData.accessToken",
                  "        );",
                  "        pm.expect(hasSignal, 'expected registration response to include meaningful data').to.be.true;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"staff1@en2h.com\",\r\n  \"password\": \"SecurePassword123!\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Log In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "",
                  "pm.test('Log In returns a success status', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Log In returns an access token', function () {",
                  "    pm.expect(jsonData).to.be.an('object');",
                  "    pm.expect(jsonData.accessToken, 'accessToken is missing from login response').to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.environment.set('jwt_token', jsonData.accessToken);",
                  "",
                  "pm.test('jwt_token environment variable was stored', function () {",
                  "    pm.expect(pm.environment.get('jwt_token')).to.eql(jsonData.accessToken);",
                  "});"
                ],
